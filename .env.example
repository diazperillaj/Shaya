# Copia este archivo a .env (junto al docker-compose.yml) y ajusta los valores.
# docker compose lo lee automáticamente.

# ── Base de datos ────────────────────────────────────────────
DB_NAME=shaya
DB_USER=shaya
DB_PASSWORD=cambia-esta-contrasena

# ── Backend ──────────────────────────────────────────────────
# Genera una clave larga y aleatoria, ej: openssl rand -hex 32
SECRET_KEY=cambia-esta-clave
# URL pública con la que se accede a la app (usada para CORS y cookies)
FRONTEND_URL=https://frontendurl

# true cuando la app se sirve por HTTPS (con Caddy, sí)
COOKIE_SECURE=true

# ── HTTPS (Caddy) ────────────────────────────────────────────
# Dominio que apunta a la IP del server. Caddy saca el certificado solo.
CADDY_DOMAIN=shaya.com

# Copia este archivo a .env (junto al docker-compose.yml) y ajusta los valores.
# docker compose lo lee automáticamente. El .env es distinto en cada máquina.
#
# El HTTPS/dominio lo maneja el reverse proxy externo (proyecto ../proxy),
# NO este compose. Aquí solo va la config de la app.

# ── Base de datos ────────────────────────────────────────────
DB_NAME=shaya
DB_USER=shaya
DB_PASSWORD=cambia-esta-contrasena

# ── Backend ──────────────────────────────────────────────────
# Genera una clave larga y aleatoria, ej: openssl rand -hex 32
SECRET_KEY=cambia-esta-clave

# ─────────────────────────────────────────────────────────────
#  LOCAL (tu PC)  →  http://localhost:8080
# ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8080
COOKIE_SECURE=false
WEB_PORT=8080

# ─────────────────────────────────────────────────────────────
#  PRODUCCIÓN (server) → descomenta y comenta el bloque LOCAL.
#  El dominio se sirve por el proxy externo (https://tu-sub.duckdns.org).
# ─────────────────────────────────────────────────────────────
# FRONTEND_URL=https://tu-sub.duckdns.org
# COOKIE_SECURE=true
# WEB_PORT=8080

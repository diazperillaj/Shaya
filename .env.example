# Copia este archivo a .env (junto al docker-compose.yml) y ajusta los valores.
# docker compose lo lee automáticamente. El .env es distinto en cada máquina.
#
# ══════════════════════════════════════════════════════════════
#  Abajo hay DOS ejemplos: uno para LOCAL y otro para PRODUCCIÓN.
#  Deja descomentado solo el bloque que corresponda a la máquina.
# ══════════════════════════════════════════════════════════════

# ── Base de datos ────────────────────────────────────────────
DB_NAME=shaya
DB_USER=shaya
DB_PASSWORD=cambia-esta-contrasena

# ── Backend ──────────────────────────────────────────────────
# Genera una clave larga y aleatoria, ej: openssl rand -hex 32
SECRET_KEY=cambia-esta-clave


# ─────────────────────────────────────────────────────────────
#  LOCAL (desarrollo en tu PC)  →  http://localhost:8080
# ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8080
COOKIE_SECURE=false
WEB_PORT=8080
# COMPOSE_PROFILES vacío: Caddy NO arranca en local.

# ─────────────────────────────────────────────────────────────
#  PRODUCCIÓN (server con dominio)  →  https://tu-sub.duckdns.org
#  Descomenta esto en el server y comenta el bloque LOCAL de arriba.
# ─────────────────────────────────────────────────────────────
# FRONTEND_URL=https://tu-sub.duckdns.org
# COOKIE_SECURE=true
# CADDY_DOMAIN=tu-sub.duckdns.org
# COMPOSE_PROFILES=prod    # activa Caddy (HTTPS) automáticamente

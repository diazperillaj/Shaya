# Copia este archivo a .env (junto al docker-compose.yml) y ajusta los valores.
# docker compose lo lee automáticamente.

# ── Base de datos ────────────────────────────────────────────
DB_NAME=shaya
DB_USER=shaya
DB_PASSWORD=cambia-esta-contrasena

# ── Backend ──────────────────────────────────────────────────
# Genera una clave larga y aleatoria, ej: openssl rand -hex 32
SECRET_KEY=cambia-esta-clave
# URL desde la que se accede a la app (informativa para CORS)
FRONTEND_URL=http://localhost

# true solo cuando la app se sirva por HTTPS
COOKIE_SECURE=false

# ── Web (nginx) ──────────────────────────────────────────────
# Puerto del servidor donde queda expuesta la app
WEB_PORT=80

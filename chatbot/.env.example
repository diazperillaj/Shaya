# ── Entorno ──────────────────────────────────────────────────────────
ENV=development

# ── Base de datos (compartida con el backend) ────────────────────────
BUSINESS_DB_HOST=db
BUSINESS_DB_PORT=5432
BUSINESS_DB_NAME=shaya

# Usuario de SOLO LECTURA sobre schema public (creado por scripts/init_db_roles.sql)
BUSINESS_DB_USER=chatbot_ro
BUSINESS_DB_PASSWORD=cambiar

# Usuario RW sobre schema chat (historial del chatbot)
CHAT_DB_USER=chatbot_app
CHAT_DB_PASSWORD=cambiar

# ── Redis (memoria conversacional caliente) ──────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Autenticación (el MISMO SECRET_KEY del backend: valida su cookie) ─
SECRET_KEY=cambiar

# CORS (mismo valor que usa el backend)
FRONTEND_URL=http://localhost:5173

# ── LLM (API OpenAI-compatible; Groq en desarrollo) ──────────────────
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_xxx
LLM_MODEL=openai/gpt-oss-120b
LLM_MODEL_LIGHT=llama-3.1-8b-instant
